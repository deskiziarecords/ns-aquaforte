# ============================================================================
# CELL 3: Generate Test Instance
# ============================================================================
from ns_aquaforte.benchmarks import generate_random_3sat, save_cnf

print("🎲 Generating random 3-SAT instance...")

# Create instance at critical phase (hardest region)
clauses = generate_random_3sat(
    n_vars=100,
    n_clauses=426,  # 4.26 ratio - critical phase
    seed=42
)

save_cnf(clauses, 'test.cnf', n_vars=100)

print("✓ Generated 100-var instance (426 clauses, density=4.26)")
print("  This is in the CRITICAL phase transition region")

# ============================================================================
# CELL 4: Baseline - MiniSAT
# ============================================================================
import time
from pysat.formula import CNF
from pysat.solvers import Minisat22

print("\n" + "="*60)
print("BASELINE: MiniSAT")
print("="*60)

problem = CNF(from_file='test.cnf')
print(f"Instance: {problem.nv} variables, {len(problem.clauses)} clauses")

start = time.time()
solver = Minisat22(bootstrap_with=problem.clauses)
result_minisat = solver.solve()
time_minisat = time.time() - start
solver.delete()

print(f"\nResult: {'SAT' if result_minisat else 'UNSAT'}")
print(f"Time: {time_minisat:.2f}s")

# ============================================================================
# CELL 5: NS-AquaForte
# ============================================================================
from ns_aquaforte.solvers import hybrid_solver

print("\n" + "="*60)
print("NS-AQUAFORTE: Hybrid Solver")
print("="*60)

# Run NS-AquaForte
result_ns = hybrid_solver(problem, verbose=True)

print(f"\n{'='*60}")
print("COMPARISON")
print('='*60)
print(f"MiniSAT:      {time_minisat:.2f}s")
print(f"NS-AquaForte: {result_ns['time']:.2f}s")
print(f"Speedup:      {time_minisat / result_ns['time']:.2f}x")
print(f"\nPhase detected: {result_ns['phase']}")
print(f"Algorithm used: {result_ns['solver']}")
if 'spectral_gap' in result_ns:
    print(f"Spectral gap: {result_ns['spectral_gap']:.4f}")

