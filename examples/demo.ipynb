# ============================================================================
# CELL 9: Batch Processing Example
# ============================================================================
from ns_aquaforte.benchmarks import run_benchmark_suite

print("\n" + "="*60)
print("BATCH PROCESSING")
print("="*60)

# Create multiple instances
print("Generating 10 test instances...")

import os
os.makedirs('./batch_test', exist_ok=True)

batch_files = []
for i in range(10):
    n_vars = 60
    n_clauses = int(4.26 * n_vars)  # Critical phase
    clauses = generate_random_3sat(n_vars, n_clauses, seed=100+i)
    filename = f'./batch_test/instance_{i:02d}.cnf'
    save_cnf(clauses, filename, n_vars=n_vars)
    batch_files.append(filename)

print(f"Created {len(batch_files)} instances")

# Batch solve
print("\nBatch solving...")
results = run_benchmark_suite(
    batch_files,
    solvers=['hybrid'],
    baseline=True,
    timeout=30
)

# Show results
total_baseline = results[results['solver'] == 'minisat_baseline']['time'].sum()
total_ns = results[results['solver'] == 'hybrid']['time'].sum()

print(f"\nTotal time:")
print(f"  MiniSAT:      {total_baseline:.2f}s")
print(f"  NS-AquaForte: {total_ns:.2f}s")
print(f"  Speedup:      {total_baseline/total_ns:.2f}x")
print(f"\nSaved {total_baseline - total_ns:.2f}s ({100*(1-total_ns/total_baseline):.1f}% reduction)")
