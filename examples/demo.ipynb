print("Generating instances across density spectrum...")

# Generate suite
files = generate_phase_transition_suite(
    output_dir='./phase_test',
    n_vars=50,  # Smaller for speed
    densities=[3.5, 4.0, 4.26, 4.5, 5.0],
    instances_per_density=3  # 15 instances total
)

